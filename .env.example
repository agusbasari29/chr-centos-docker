# =============================================================
# CHR + CentOS Docker Stack - Environment Configuration
# =============================================================

# --- MikroTik CHR ---
CHR_IMAGE=evilfreelancer/docker-routeros
CHR_VERSION=6.49.19

# Default admin credentials (GANTI sebelum deploy!)
CHR_ADMIN_PASSWORD=your_strong_password_here

# --- Network (satu network untuk CHR + CentOS) ---
CHR_SUBNET=192.168.100.0/24
CHR_GATEWAY=192.168.100.254

# IP CHR (VPN gateway + Winbox/API)
CHR_IP=192.168.100.1

# IP CentOS backend
CENTOS_IP=192.168.100.10

# --- VPN (konfigurasi oleh client) ---
WG_PORT=51820
L2TP_PORT=1701
PPTP_PORT=1723
SSTP_PORT=443

# --- Port Forwarding ke CentOS (opsional) ---
# HTTP_PORT=8080
# HTTPS_PORT=8443
# SSH_PORT=2222
