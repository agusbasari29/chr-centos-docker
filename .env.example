# =============================================================
# CHR + CentOS Docker Stack - Environment Configuration
# =============================================================

# --- MikroTik CHR ---
CHR_IMAGE=evilfreelancer/docker-routeros
CHR_VERSION=latest

# Default admin credentials (GANTI sebelum deploy!)
CHR_ADMIN_PASSWORD=your_strong_password_here

# CHR Management IP (akses Winbox/API)
CHR_MGMT_IP=172.20.0.2

# CHR Internal (gateway untuk CentOS)
CHR_INTERNAL_IP=192.168.100.1

# --- CentOS ---
CENTOS_IMAGE=centos:7.9.2009
CENTOS_INTERNAL_IP=192.168.100.10

# --- Networks ---
MGMT_SUBNET=172.20.0.0/24
MGMT_GATEWAY=172.20.0.1

INTERNAL_SUBNET=192.168.100.0/24
INTERNAL_GATEWAY=192.168.100.1

# --- VPN (konfigurasi oleh client) ---
# WireGuard port
WG_PORT=51820

# L2TP/IPSec port
L2TP_PORT=1701

# PPTP port
PPTP_PORT=1723

# SSTP port
SSTP_PORT=443

# --- Port Forwarding ke CentOS (opsional) ---
# Aktifkan jika CentOS perlu diakses dari luar via CHR NAT
# HTTP_PORT=8080
# HTTPS_PORT=8443
# SSH_PORT=2222
